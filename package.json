    "deploy:party": "partykit deploy"
  },
  "devDependencies": {
    "partykit": "^0.0.111",
    "y-partykit": "^0.0.33"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "esbuild@0.21.5": true,
    "sqlite3@5.1.7": true,
    "workerd@1.20240718.0": true,
    "fsevents@2.3.3": true
  }
}
