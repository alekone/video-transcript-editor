{
  "name": "video-transcript-editor",
  "version": "0.1.0",
  "private": true,
  "description": "Editor di trascrizioni per content creator: trascrivi in locale, edita il testo e monta in DaVinci/Premiere/FCP.",
  "author": "Flatmates",
  "license": "MIT",
  "type": "module",
  "main": "electron/main.cjs",
  "workspaces": [
    "client",
    "server"
  ],
  "bin": {
    "trascrivi": "scripts/transcribe.mjs"
  },
  "scripts": {
    "dev": "npm run dev --workspace=server & npm run dev --workspace=client",
    "dev:client": "npm run dev --workspace=client",
    "dev:server": "npm run dev --workspace=server",
    "start:server": "npm run start --workspace=server",
    "build:client": "npm run build --workspace=client",
    "transcribe": "node scripts/transcribe.mjs",
    "app": "electron electron/main.cjs",
    "app:dev": "npm run dev:client & (until curl -sf http://localhost:5173/v-editor/ >/dev/null; do sleep 0.5; done; electron electron/main.cjs)",
    "build:app-renderer": "ELECTRON=1 npm run build --workspace=client",
    "dist:mac": "npm run build:app-renderer && electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.mininno.veditor",
    "productName": "v-editor",
    "directories": { "output": "release" },
    "files": [
      "electron/**",
      "client/dist-electron/**",
      "package.json"
    ],
    "extraResources": [
      { "from": "scripts", "to": "engine/scripts" },
      { "from": "models/diarization", "to": "engine/models/diarization" }
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.video",
      "icon": "build/icon.icns",
      "identity": null
    }
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "esbuild@0.21.5": true,
    "sqlite3@5.1.7": true,
    "workerd@1.20240718.0": true,
    "fsevents@2.3.3": true,
    "electron@33.4.11": true
  }
}
